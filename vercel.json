{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/internal/job-worker",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/deadline-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/document-reminders",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/overdue-detection",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/invoice-reminders",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/aging-recalculation",
      "schedule": "0 4 * * *"
    }
  ]
}
