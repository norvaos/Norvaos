# =============================================================================
# NorvaOS Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# Supabase Configuration
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NorvaOS

# Stripe Configuration (for billing/subscriptions)
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products/prices in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Resend Email Configuration (for automated client notifications)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_DOMAIN=notifications.norvaos.com

# Upstash Redis (optional — cache layer for scale)
# Get these from: https://console.upstash.com
# When not set, caching is disabled (no-op). This is the rollback mechanism.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Browser Push Notifications (optional — VAPID keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@norvaos.com

# Microsoft 365 Integration (Azure AD App Registration)
# Register at: https://portal.azure.com > Azure Active Directory > App registrations
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# Symmetric encryption key for OAuth tokens at rest (32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MICROSOFT_TOKEN_ENCRYPTION_KEY=

# Platform Token Encryption (shared across GHL, Clio, and Microsoft integrations)
# 32-byte hex key for AES-256-GCM encryption of OAuth tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_TOKEN_ENCRYPTION_KEY=

# Go High Level Integration (GHL Marketplace OAuth)
# Register at: https://marketplace.gohighlevel.com > My Apps > Create App
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/ghl/callback
# Scopes: contacts.readonly, contacts.write, opportunities.readonly, etc.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Clio Integration (standard OAuth 2.0)
# Register at: https://app.clio.com/nc/#/settings/developer_applications
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/integrations/clio/callback
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# Supabase Connection Pool: Minimum Pro tier (200 pooler connections)
# For 1000+ tenants: Team tier recommended (1000+ pooler connections)

# Python Worker Sidecar (FastAPI for PDF processing)
# The worker handles XFA scanning, filling, and preview rendering.
# Run with: cd worker && docker compose up
PYTHON_WORKER_URL=http://localhost:8100
PYTHON_WORKER_SECRET=

# Supabase DB Direct Connection (for migration scripts only)
# Get from: Supabase Dashboard > Project Settings > Database > Connection string
# SUPABASE_DB_USER=postgres.your-project-ref
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_HOST=aws-0-ca-central-1.pooler.supabase.com
# SUPABASE_DIRECT_HOST=db.your-project-ref.supabase.co
